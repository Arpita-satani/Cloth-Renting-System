<%@ Page Title="About Us" Language="C#" MasterPageFile="~/Site.Master"
    AutoEventWireup="true" %>

<asp:Content ID="Content1" ContentPlaceHolderID="MainContent" runat="server">

<section class="about-premium">

    <!-- INTRO -->
    <div class="about-intro">
        <h1>About ClothRent</h1>
        <p class="intro-text">
            A modern approach to fashion renting, designed for elegance,
            sustainability, and smart living.
        </p>
    </div>

    <!-- SECTION 1 -->
    <div class="about-row">
        <div class="about-text">
            <h2>Who We Are</h2>
            <p>
                ClothRent is a premium clothing rental platform created for individuals
                who value quality, style, and conscious choices. We bring carefully
                curated outfits that allow you to dress exceptionally for every
                occasion—without owning excess.
            </p>
        </div>
    </div>

    <!-- SECTION 2 -->
    <div class="about-row alt">
        <div class="about-text">
            <h2>Our Story</h2>
            <p>
                Founded with the belief that fashion should be both luxurious and
                responsible, ClothRent began as a solution to overconsumption.
                Today, we serve customers who want premium fashion without compromise.
            </p>
        </div>
    </div>

    <!-- SECTION 3 -->
    <div class="about-row">
        <div class="about-text">
            <h2>Our Mission</h2>
            <p>
                Our mission is to make high-quality fashion accessible while promoting
                sustainability. Every outfit you rent contributes to a smarter,
                more responsible fashion ecosystem.
            </p>
        </div>
    </div>

    <!-- SECTION 4 -->
    <div class="about-row highlight">
        <div class="about-text">
            <h2>Why Choose ClothRent</h2>
            <ul>
                <li>Premium, curated collections</li>
                <li>Affordable luxury for every occasion</li>
                <li>Hygienic, quality-checked garments</li>
                <li>Easy booking, delivery & returns</li>
            </ul>
        </div>
    </div>

</section>

</asp:Content>
